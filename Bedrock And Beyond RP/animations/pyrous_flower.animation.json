                    ]
                }
            }
        },
        "animation.bs_bb.pyrous_flower.default": {
            "loop": true,
            "bones": {
                "root": {
                    "rotation": ["v.rot_x", "v.rot_y", "v.rot_z"]
                }
            }
        }
    }
}

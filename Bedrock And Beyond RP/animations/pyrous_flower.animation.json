{
    "format_version": "1.8.0",
    "animations": {
        "animation.bs_bb.pyrous_flower.falling": {
            "loop": true,
            "bones": {
                "root": {
                    "rotation": [
                        "-15*math.cos(q.anim_time*45)",
                        "-720 * (q.anim_time - (1 / 0.8) * (1 - Math.exp(-0.8 * q.anim_time)))",

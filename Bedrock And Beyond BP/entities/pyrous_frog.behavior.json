{
    "format_version": "1.16.0",
    "minecraft:entity": {
        "description": {
            "identifier": "bs_bb:pyrous_frog",
            "is_spawnable": true,
            "is_summonable": true,
            "is_experimental": false,
            "properties": {
                "bs_bb:pyrous_state": {
                    "type": "int",
                    "range": [0, 3],
                    "default": 0,
                    "client_sync": true
                }
            }
        },
        "component_groups": {
            "pregnant": {
                "minecraft:behavior.move_to_liquid": {
                    "priority": 1,
                    "search_range": 16,
                    "search_height": 10,
                    "goal_radius": 0.9,
                    "material_type": "Lava",
                    "search_count": 30
                },
                "minecraft:behavior.lay_egg": {
                    "priority": 2,
                    "speed_multiplier": 1,
                    "search_range": 10,
                    "search_height": 5,
                    "goal_radius": 1.7,
                    "target_blocks": ["minecraft:lava", "minecraft:magma"],
                    "target_materials_above_block": ["Air"],
                    "allow_laying_from_below": true,
                    "use_default_animation": false,
                    "lay_seconds": 2,
                    "egg_type": "minecraft:amethyst_block",
                    "lay_egg_sound": "lay_spawn",
                    "on_lay": {
                        "event": "laid_egg",
                        "target": "self"
                    }
                }
            }
        },
        "components": {
            "minecraft:fire_immune": {},
            "minecraft:is_hidden_when_invisible": {},
            "minecraft:type_family": {
                "family": ["frog", "mob"]
            },
            "minecraft:collision_box": {
                "width": 1.1,
                "height": 1.1
            },
            "minecraft:experience_reward": {
                "on_bred": "Math.Random(1,7)",
                "on_death": "query.last_hit_by_player ? Math.Random(1,3) : 0"
            },
            "minecraft:nameable": {},
            "minecraft:health": {
                "value": 20
            },
            "minecraft:hurt_on_condition": {
                "damage_conditions": [
                    {
                        "filters": {
                            "test": "in_water",
                            "subject": "self",
                            "operator": "==",
                            "value": true
                        },
                        "cause": "drowning",
                        "damage_per_tick": 4
                    }
                ]
            },
            "minecraft:damage_sensor": {
                "triggers": {
                    "cause": "fall",
                    "deals_damage": true,
                    "damage_modifier": -5
                }
            },
            "minecraft:navigation.walk": {
                "can_path_over_lava": true,
                "avoid_water": true,
                "can_sink": false,
                "can_walk_in_lava": true
            },
            "minecraft:lava_movement": {
                "value": 0.32
            },
            "minecraft:movement": {
                "value": 0.12
            },
            "minecraft:movement.basic": {},
            "minecraft:jump.static": {},
            "minecraft:physics": {},
            "minecraft:pushable": {},
            "minecraft:leashable": {},
            "minecraft:despawn": {
                "despawn_from_distance": {}
            },
            "minecraft:breedable": {
                "require_tame": false,
                "causes_pregnancy": true,
                "breeds_with": {
                    "mate_type": "bs_bb:pyrous_frog",
                    "baby_type": "minecraft:tadpole",
                    "breed_event": {
                        "event": "become_pregnant"
                    }
                },
                "breed_items": ["magma_cream", "rotten_flesh"]
            },
            "minecraft:behavior.panic": {
                "priority": 1,
                "speed_multiplier": 2
            },
            "minecraft:behavior.breed": {
                "priority": 4
            },
            "minecraft:behavior.tempt": {
                "priority": 5,
                "speed_multiplier": 1.25,
                "can_tempt_vertically": true,
                "items": ["magma_cream"]
            },
            "minecraft:behavior.move_to_land": {
                "priority": 6,
                "search_range": 30,
                "search_height": 8,
                "search_count": 80,
                "goal_radius": 2
            },
            "minecraft:behavior.eat_mob": {
                "priority": 7,
                "run_speed": 2.5,
                "eat_animation_time": 0.3,
                "pull_in_force": 0.9,
                "reach_mob_distance": 4,
                "eat_mob_sound": "tongue",
                "loot_table": "loot_tables/pyrous_frog.json"
            },
            "minecraft:behavior.nearest_attackable_target": {
                "priority": 8,
                "within_radius": 16,
                "entity_types": [
                    {
                        "filters": {
                            "all_of": [
                                {
                                    "test": "is_family",
                                    "subject": "other",
                                    "value": "slime"
                                }
                            ]
                        },
                        "max_dist": 16
                    },
                    {
                        "filters": {
                            "all_of": [
                                {
                                    "test": "int_property",
                                    "domain": "bs_bb:pyrous_state",
                                    "operator": "<",
                                    "value": 3
                                },
                                {
                                    "test": "is_family",
                                    "subject": "other",
                                    "value": "pyrous_plant"
                                }
                            ]
                        },
                        "max_dist": 16
                    },
                    {
                        "filters": {
                            "all_of": [
                                {
                                    "test": "is_family",
                                    "subject": "other",
                                    "value": "zombie"
                                },
                                {
                                    "test": "on_fire",
                                    "subject": "other",
                                    "operator": "==",
                                    "value": true
                                }
                            ]
                        },
                        "max_dist": 16
                    },
                    {
                        "filters": {
                            "all_of": [
                                {
                                    "test": "is_family",
                                    "subject": "other",
                                    "value": "magmacube"
                                }
                            ]
                        },
                        "max_dist": 16
                    }
                ],
                "must_see": true
            },
            "minecraft:behavior.croak": {
                "priority": 9,
                "interval": [10, 20],
                "duration": 4.5,
                "filters": {
                    "all_of": [
                        {
                            "test": "in_water",
                            "value": false
                        },
                        {
                            "test": "in_lava",
                            "value": false
                        }
                    ]
                }
            },
            "minecraft:behavior.jump_to_block": {
                "priority": 10,
                "search_width": 8,
                "search_height": 4,
                "minimum_path_length": 2,
                "minimum_distance": 1,
                "scale_factor": 0.6,
                "max_velocity": 1.2,
                "cooldown_range": [5, 7],
                "preferred_blocks": ["minecraft:magma"],
                "preferred_blocks_chance": 0.5,
                "forbidden_blocks": ["minecraft:water", "minecraft:lava"]
            },
            "minecraft:timer": {
                "time": 10,
                "time_down_event": {
                    "event": "bs_bb:zombie_wanted"
                }
            },
            "minecraft:behavior.random_stroll": {
                "priority": 11
            },
            "minecraft:behavior.look_at_player": {
                "priority": 12,
                "target_distance": 6,
                "probability": 0.02
            },
            "minecraft:behavior.look_at_entity": {
                "priority": 13,
                "look_distance": 6,
                "probability": 0.5,
                "filters": {
                    "test": "is_family",
                    "subject": "other",
                    "value": "zombie"
                }
            }
        },
        "events": {
            "become_pregnant": {
                "add": {
                    "component_groups": ["pregnant"]
                }
            },
            "laid_egg": {
                "remove": {
                    "component_groups": ["pregnant"]
                }
            },
            "bs_bb:zombie_wanted": {
                "queue_command": {
                    "command": "scriptevent bs_bb:zombie_wanted"
                }
            }
        }
    }
}
